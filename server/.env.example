PORT=8000
NODE_ENV=development
# Change this in real projects
JWT_SECRET=replace_me_with_a_long_random_string
JWT_EXPIRES_IN=7d
# For local MongoDB:
# MONGODB_URI=mongodb://127.0.0.1:27017/expense-tracker
#
# For MongoDB Atlas (if your URI includes <PASSWORD> placeholder):
MONGODB_URI=mongodb+srv://expense-tracker:<PASSWORD>@cluster0.rab3xsz.mongodb.net/expense-tracker?retryWrites=true&w=majority
DATABASE_PASSWORD=your_password_here
#
# Optional (comma separated). If unset, all origins are allowed.
CORS_ORIGIN=http://localhost:5173

